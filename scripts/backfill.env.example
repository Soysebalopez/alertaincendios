# Copy to scripts/backfill.env and fill in.
# Then: chmod 600 scripts/backfill.env
# The real .env file is in .gitignore so it never gets committed.

# NASA FIRMS API key — get one at https://firms.modaps.eosdis.nasa.gov/api/area/
MAP_KEY=PASTE_YOUR_FIRMS_MAP_KEY_HERE

# Supabase Personal Access Token — Supabase dashboard → Account → Access Tokens
# This token has full project access — keep secret.
SUPABASE_TOKEN=PASTE_YOUR_SUPABASE_PAT_HERE

# Optional overrides
# BBOX=-73.6,-55.1,-53.6,-21.8
# SUPABASE_URL=https://api.supabase.com/v1/projects/qmzuwnilehldvobjsbcs/database/query
